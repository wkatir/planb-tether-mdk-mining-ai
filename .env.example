# === Application ===
APP_ENV=development
LOG_LEVEL=INFO

# === Data ===
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MODELS_DIR=./data/models

# === Synthetic Data ===
FLEET_SIZE=50
SIMULATION_DAYS=30
SAMPLE_INTERVAL_MINUTES=1
FAILURE_INJECTION_RATE=0.05

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app
