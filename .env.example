# === Application ===
APP_ENV=development
LOG_LEVEL=INFO

# === Data ===
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MODELS_DIR=./data/models

# === Synthetic Data ===
FLEET_SIZE=50
SIMULATION_DAYS=30
SAMPLE_INTERVAL_MINUTES=1
FAILURE_INJECTION_RATE=0.15

# === DuckDB ===
DUCKDB_PATH=./data/mining.duckdb

# === AI Layer (NVIDIA NIM - OpenAI-compatible) ===
# Get a free key at https://build.nvidia.com (1000 credits on signup, prefix: nvapi-)
NVIDIA_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=google/gemma-3-27b-it
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# === Email alerts (optional - falls back to ./data/alerts.log if unset) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OPERATOR_EMAIL=
