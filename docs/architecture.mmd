graph TD
    subgraph HW["Layer 0 - Hardware"]
        ASIC["ASIC Fleet\nS21 | S21 Pro | S21 XP | M60S"]
        SENS["Site Sensors\nAmbient | Cooling | Power"]
    end

    subgraph MDK["Layer 1 - MDK Core (JavaScript, Tether)"]
        WORK["MDK Workers\nDevice Adapters"]
        HB["Hyperbee\nTime-series KV"]
        HRPC["HRPC\nAuthenticated RPC"]
        ORCH["Orchestrator\nLean Core"]
    end

    subgraph INGEST["Layer 2 - Ingestion (Python, this project)"]
        ING["Pydantic validation\nphysical bounds"]
        DB["DuckDB\nembedded analytics"]
    end

    subgraph FE["Layer 3 - Feature Engineering"]
        WIN["Rolling window SQL\n5m / 1h, z-scores,\ndT/dt, dP/dt"]
    end

    subgraph ML["Layer 4 - ML Analytics"]
        KPI["KPI Engine\nTE | ETE | PD"]
        AD["LSTM Autoencoder\ntemporal anomaly"]
        IFM["Isolation Forest\nglobal outlier"]
        FC["XGBoost + SHAP\nfailure classifier"]
        HS["Health Score\n0.4*anomaly + 0.6*fail"]
        RL["PPO Agent\nSB3 / Gymnasium"]
    end

    subgraph LLM["Layer 5 - AI Assistant"]
        GEM["Gemma 3 27B Instruct\nvia NVIDIA NIM\n(OpenAI-compatible)"]
        TOOLS["Tool Registry\nget_fleet_summary\nget_device_status\nlist_miners_at_risk\nrecommend_action\nsend_operator_alert"]
        AGENT["FleetAgent\ntool-calling loop"]
    end

    subgraph SAFE["Layer 6 - Decision Engine"]
        DE["3-tier gate:\nSafety > AI > Operator\nhard thermal/voltage limits\nrate limit 5 min/device"]
    end

    subgraph OUT["Layer 7 - Outputs"]
        CMD["Control Commands\nJSON schema"]
        DASH["Streamlit Dashboard\n6 tabs incl. Synthetic Data\nand AI Assistant"]
        ONNX["ONNX Artefacts\nedge deployment on\nMOS lib-workers"]
        MAIL["Operator Alerts\nSMTP or local log"]
    end

    ASIC -->|"telemetry"| WORK
    SENS -->|"sensor data"| WORK
    WORK --> HB
    WORK --> ORCH
    ORCH --> HRPC
    HRPC -->|"Parquet / HRPC"| ING
    ING --> DB
    DB --> WIN
    WIN --> KPI
    WIN --> AD
    WIN --> IFM
    WIN --> FC
    AD --> HS
    IFM --> HS
    FC --> HS
    KPI --> RL
    HS --> DE
    RL --> DE
    KPI --> TOOLS
    HS --> TOOLS
    FC --> TOOLS
    TOOLS --> AGENT
    AGENT -->|"prompt + tool results"| GEM
    GEM -->|"tool calls / answer"| AGENT
    AGENT -->|"advisory action"| DE
    AGENT --> MAIL
    DE --> CMD
    CMD -->|"set clock/voltage/fan"| WORK
    KPI --> DASH
    HS --> DASH
    AGENT --> DASH
    AD --> ONNX
    FC --> ONNX
